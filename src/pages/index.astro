---
// @ts-nocheck
// Astro Component Frontmatter
import "../styles/style.css";
import { getCollection } from "astro:content";

/** @type {any[]} */
const allStories = await getCollection("story");

/**
 * Parse story body into structured scenario data
 * @param {string} body
 * @param {string} storyId
 * @returns {any}
 */
function parseStoryBody(body, storyId) {
    const lines = body.split(/\r?\n/);

    let view = "talk";
    let arcana = "";
    let speaker = "ナレーション";
    let choiceIllusion = false;
    let focusImage = null;
    let focusTitle = null;
    let transition = null;

    const allowedMetaKeys = [
        "view",
        "arcana",
        "speaker",
        "choiceIllusion",
        "focusImage",
        "focusTitle",
        "transition"
    ];

    let currentLineIndex = 0;
    while (currentLineIndex < lines.length) {
        const line = lines[currentLineIndex].trim();
        if (line.startsWith("[") && line.endsWith("]")) {
            const inner = line.slice(1, -1);
            const colonIndex = inner.indexOf(":");
            if (colonIndex !== -1) {
                const key = inner.slice(0, colonIndex).trim();
                const val = inner.slice(colonIndex + 1).trim();

                if (allowedMetaKeys.includes(key)) {
                    if (key === "view") view = val;
                    else if (key === "arcana") arcana = val;
                    else if (key === "speaker") speaker = val;
                    else if (key === "choiceIllusion")
                        choiceIllusion = val === "true";
                    else if (key === "focusImage") focusImage = val;
                    else if (key === "focusTitle") focusTitle = val;
                    else if (key === "transition") transition = val;
                    currentLineIndex++;
                } else {
                    break;
                }
            } else {
                break;
            }
        } else if (line === "") {
            currentLineIndex++;
        } else {
            break;
        }
    }

    const remainingLines = lines.slice(currentLineIndex);
    const fullText = remainingLines.join("\n");

    // 選択肢分岐の切り離し
    const branchMarker = /#\s*---\s*(?:以下、選択肢分岐\s*---)?/;
    const markerIndex = fullText.search(branchMarker);

    let text = fullText;
    let branchText = "";
    if (markerIndex !== -1) {
        text = fullText.substring(0, markerIndex).trim();
        branchText = fullText
            .substring(markerIndex)
            .replace(branchMarker, "")
            .trim();
    } else {
        const firstChoiceIndex = fullText.indexOf("- 選択肢:");
        if (firstChoiceIndex !== -1) {
            text = fullText.substring(0, firstChoiceIndex).trim();
            branchText = fullText.substring(firstChoiceIndex).trim();
        }
    }

    const cards = /** @type {any[]} */ ([]);
    if (branchText) {
        let commonText = "";
        const commonMarker = /\[common\]/;
        const commonIndex = branchText.search(commonMarker);
        if (commonIndex !== -1) {
            commonText = branchText.substring(commonIndex).replace(commonMarker, "").trim();
            branchText = branchText.substring(0, commonIndex).trim();
        }

        const choiceBlocks = branchText.split(
            /(?=\n-\s*(?:選択肢|モチーフ選択):)|^(?=-\s*(?:選択肢|モチーフ選択):)/m,
        );
        choiceBlocks.forEach((block) => {
            const trimmedBlock = block.trim();
            if (!trimmedBlock) return;

            const blockLines = trimmedBlock.split("\n");
            const titleLine = blockLines[0];
            const titleMatch = titleLine.match(/^-\s*(選択肢|モチーフ選択):\s*(.*)$/);
            if (!titleMatch) return;

            const isMotif = titleMatch[1] === "モチーフ選択";
            const title = titleMatch[2].trim();
            let upright = false;
            let correct = undefined;
            let skipFocus = false;
            let id = 0;

            let descStartLine = 1;
            if (blockLines[1]) {
                const optionMatch = blockLines[1]
                    .trim()
                    .match(/^\[option:\s*(.*)\s*\]$/);
                if (optionMatch) {
                    const optionsList = optionMatch[1]
                        .split(",")
                        .map((o) => o.trim());
                    optionsList.forEach((opt) => {
                        if (opt.startsWith("id=")) {
                            const val = opt.split("=")[1];
                            id = isNaN(parseInt(val, 10)) ? val.trim() : parseInt(val, 10);
                        } else if (opt === "upright") {
                            upright = true;
                        } else if (opt === "correct") {
                            correct = true;
                        } else if (opt === "incorrect") {
                            correct = false;
                        } else if (opt === "skipFocus") {
                            skipFocus = true;
                        }
                    });
                    descStartLine = 2;
                }
            }

            // desc の抽出
            const descLines = blockLines.slice(descStartLine);
            // 行頭のインデントを除去
            const cleanedDescLines = descLines.map((line) => {
                return line.replace(/^( {2,4}|\t)/, "");
            });
            let desc = cleanedDescLines.join("\n").trim();
            if (commonText) {
                desc = (desc + "\n\n" + commonText).trim();
            }

            cards.push({
                id,
                title,
                upright,
                correct,
                skipFocus,
                isMotif,
                desc,
            });
        });
    }

    return {
        view,
        arcana,
        speaker,
        text,
        choiceIllusion,
        focusImage,
        focusTitle,
        transition,
        cards,
    };
}

const scenarioData = /** @type {Record<number, any[]>} */ ({});
allStories.forEach((/** @type {{id:string, body:string}} */ story) => {
    const idMatch = story.id.match(/loop-(\d)[-\/]step-(\d+)/);
    if (!idMatch) {
        console.warn(`Unrecognized story ID format: ${story.id}`);
        return;
    }
    const loopNum = parseInt(idMatch[1], 10);
    const stepNum = parseInt(idMatch[2], 10);

    if (!scenarioData[loopNum]) {
        scenarioData[loopNum] = [];
    }

    scenarioData[loopNum][stepNum] = parseStoryBody(story.body, story.id);
});
