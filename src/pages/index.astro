<!doctype html>
<html lang="ja">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>PhiloSofia's Journey（フィロソフィアの旅路） | 対話型タロット内省ノベルゲーム</title>
        <meta name="description" content="タロットカード「愚者の旅」を追体験し、自己対話と選択を通じて運命を切り拓くアドベンチャーゲーム『PhiloSofia's Journey（フィロソフィアの旅路）』。1周目のシステムによる支配、2周目のフィロとの対話と内省から、真の自律的な旅が始まります。" />
        <!-- Google Fonts: 神秘的なCinzel、モダンなMontserrat、デバッグ用のShare Tech Mono -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;600&family=Share+Tech+Mono&display=swap"
            rel="stylesheet"
        />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="manifest" href="/manifest.json" />
        <meta name="theme-color" content="#d4af37" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
        <link rel="apple-touch-icon" href="/images/icons/icon-192.png" />

        <script is:inline>
            if ('serviceWorker' in navigator) {
                window.addEventListener('load', () => {
                    navigator.serviceWorker.register('/sw.js')
                        .then((reg) => console.log('ServiceWorker registered', reg))
                        .catch((err) => console.error('ServiceWorker registration failed', err));
                });
            }
        </script>
    </head>
    <body>
        <div id="game-wrapper">
            <!-- 神秘的な全画面シーン背景 -->
            <div class="scene-background" id="scene-bg"></div>
            <!-- 背景のグラデーションやパーティクル効果用 -->
            <div class="bg-glow"></div>
            <div class="glitch-overlay" id="glitch-overlay"></div>
            <!-- 精神スキャンのデータ表示用オーバーレイ -->
            <div id="psyche-scan-overlay" class="hidden"></div>
            <!-- ゴールドフラッシュ演出用オーバーレイ -->
            <div class="gold-flash-overlay" id="gold-flash-overlay"></div>

            <!-- スタート画面（タイトル画面） -->
            <div id="start-screen" class="start-screen-overlay">
                <div class="start-screen-content">
                    <!-- 浮遊し、タップで反転するスタートカード -->
                    <div id="start-card-trigger" class="start-card-wrapper">
                        <div class="start-card-inner">
                            <div class="start-card-face start-card-back">
                                <div class="tarot-back-pattern"></div>
                                <div class="tap-to-reveal">カードに触れる</div>
                            </div>
                            <div
                                class="start-card-face start-card-front"
                                style="background-image: url('/images/cards/0.jpg');"
                            >
                                <div class="card-inner-glow"></div>
                            </div>
                        </div>
                    </div>

                    <!-- カードタップ後にフェードインする情報ゾーン -->
                    <div id="start-info-zone" class="start-info-zone hidden">
                        <h1 class="game-title-logo">PhiloSofia's Journey</h1>
                        <h2 class="game-subtitle-logo">
                            ― 運命をめぐる、あなたとタロットカードの旅 ―
                        </h2>
                        <div class="start-button-group" style="display: flex; flex-direction: column; gap: 12px; align-items: center; width: 100%; max-width: 280px; margin: 0 auto;">
                            <button id="start-new-btn" class="action-btn"
                                >物語を紡ぐ (最初から)</button
                            >
                            <button id="start-slots-btn" class="action-btn"
                                >セーブデータ選択</button
                            >
                            <button id="start-chapters-btn" class="action-btn"
                                >チャプターセレクト</button
                            >
                            <button id="start-meditation-btn" class="action-btn hidden"
                                >対話鑑賞モード</button
                            >
                            <a href="/about" class="about-link" style="margin-top: 10px;">📖 このアプリについて</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 対話鑑賞モード工事中モーダル -->
            <div id="construction-modal" class="custom-modal hidden">
                <div class="custom-modal-overlay"></div>
                <div class="custom-modal-content" style="text-align: center; padding: 40px 20px;">
                    <button
                        id="close-construction-btn"
                        class="custom-modal-close"
                        style="position: absolute; top: 10px; right: 15px; background: none; border: none; color: var(--color-text-muted); font-size: 24px; cursor: pointer;"
                    >&times;</button
                    >
                    <h3 style="font-family: var(--font-serif); color: var(--color-gold); font-size: 24px; margin-bottom: 15px;">UNDER CONSTRUCTION</h3>
                    <p style="color: var(--color-text-light); font-size: 16px; margin-bottom: 10px;">対話鑑賞モードは現在工事中です。</p>
                    <p style="color: var(--color-text-muted); font-size: 14px;">今後のアップデートをお楽しみに！</p>
                </div>
            </div>

            <!-- ヘッダー・ステータスバー -->
            <header id="status-bar">
                <div class="status-left">
                    <span class="status-label">LOOP:</span>
                    <span id="loop-count" class="status-val">1</span>
                    <span class="status-separator" style="opacity: 0.3;">|</span
                    >
                    <span class="status-label">STRESS:</span>
                    <span id="stress-gauge" class="status-val">80%</span>
                    <span class="status-separator" style="opacity: 0.3;">|</span
                    >
                    <span class="status-label">LUCK:</span>
                    <span id="luck-gauge" class="status-val">15%</span>
                </div>
                <div class="status-title">PROJECT FOOL</div>
                <div class="status-right">
                    <span class="status-label">ARCANA:</span>
                    <span id="current-arcana" class="status-val"
                        >0 : THE FOOL</span
                    >
                    <button
                        id="sound-btn"
                        class="icon-btn"
                        title="音声のミュート切り替え"
                        aria-label="音声ミュート切り替え"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            width="18"
                            height="18"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"
                            ></polygon>
                            <path
                                d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"
                            ></path>
                        </svg>
                    </button>
                    <button
                        id="log-btn"
                        class="icon-btn"
                        title="会話ログ（バックログ）を表示"
                        aria-label="会話ログ表示"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            width="18"
                            height="18"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <line x1="4" y1="6" x2="20" y2="6"></line>
                            <line x1="4" y1="12" x2="20" y2="12"></line>
                            <line x1="4" y1="18" x2="14" y2="18"></line>
                        </svg>
                    </button>
                    <button
                        id="auto-btn"
                        class="icon-btn"
                        title="オート（自動テキスト送り）の切り替え"
                        aria-label="自動送り切り替え"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            width="18"
                            height="18"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <polygon points="10 8 16 12 10 16 10 8"></polygon>
                        </svg>
                    </button>
                    <button
                        id="skip-btn"
                        class="icon-btn"
                        title="スキップ（早送り）の切り替え"
                        aria-label="早送り切り替え"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            width="18"
                            height="18"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <polygon points="5 4 15 12 5 20 5 4"></polygon>
                            <polygon points="11 4 21 12 11 20 11 4"></polygon>
                        </svg>
                    </button>
                    <button
                        id="slots-menu-btn"
                        class="icon-btn"
                        title="セーブ / ロードメニューを開く"
                        aria-label="セーブロードメニュー"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            width="18"
                            height="18"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                            <polyline points="17 21 17 13 7 13 7 21"></polyline>
                            <polyline points="7 3 7 8 15 8"></polyline>
                        </svg>
                    </button>
                </div>
            </header>

            <!-- メインゲームエリア -->
            <!-- メインゲームエリア (マルチシーン構成) -->
            <main id="game-container">
                <!-- 【シーン1: 占い店での対面対話】 -->
                <div id="view-talk" class="game-view">
                    <section class="visual-area-talk" style="display: none;">
                        <div class="oracle-avatar-container">
                            <div class="oracle-portrait" id="talk-portrait">
                            </div>
                            <div class="oracle-circle-magic"></div>
                            <div class="oracle-name">SOPHIA</div>
                        </div>
                    </section>
                    <section class="dialogue-container-talk">
                        <div class="dialogue-box">
                            <div class="speaker-name hidden" id="talk-speaker">
                            </div>
                            <div class="text-content" id="talk-text"></div>
                            <div class="click-prompt" id="talk-click-prompt">
                                ▼
                            </div>
                        </div>
                    </section>
                    <section class="cards-area-talk">
                        <div class="cards-container" id="talk-cards-container">
                        </div>
                    </section>
                </div>

                <!-- 【シーン2: アプリ『The Journey』チャット画面】 -->
                <div id="view-chat" class="game-view hidden">
                    <div class="chat-app-container">
                        <div class="chat-header">
                            <div class="chat-avatar">👁️</div>
                            <div class="chat-header-info">
                                <span class="chat-name">The Journey</span>
                                <span class="chat-status">オンライン</span>
                            </div>
                            <button
                                id="collection-btn"
                                class="collection-btn"
                                title="引いたカード図鑑">📖 カード図鑑</button
                            >
                        </div>
                        <div class="chat-history" id="chat-history">
                            <!-- 動的にチャット吹き出しが追加される -->
                        </div>
                        <div
                            class="chat-interactive-zone"
                            id="chat-interactive-zone"
                        >
                            <!-- カード選択、モチーフ選択、ボタン等をここに挿入 -->
                        </div>
                    </div>
                </div>

                <!-- 【シーン3: スリーカードスプレッド儀式】 -->
                <div id="view-three-card" class="game-view hidden">
                    <div class="three-card-container">
                        <div class="three-card-layout" id="three-card-grid">
                            <div
                                class="cross-slot-guide three-card-1"
                                data-slot-num="1"
                                style="grid-area: past;"
                            >
                            </div>
                            <div
                                class="cross-slot-guide three-card-2"
                                data-slot-num="2"
                                style="grid-area: present;"
                            >
                            </div>
                            <div
                                class="cross-slot-guide three-card-3"
                                data-slot-num="3"
                                style="grid-area: future;"
                            >
                            </div>
                            <div
                                class="card-wrapper three-card-deck"
                                id="three-card-deck"
                            >
                            </div>
                        </div>
                    </div>
                    <section class="dialogue-container-three-card">
                        <div class="dialogue-box">
                            <div
                                class="speaker-name hidden"
                                id="three-card-speaker"
                            >
                            </div>
                            <div class="text-content" id="three-card-text"></div>
                            <div class="click-prompt" id="three-card-click-prompt">
                                ▼
                            </div>
                        </div>
                    </section>
                </div>

                <!-- 【シーン4: 2周目の意思決定石碑パズル】 -->
                <div id="view-puzzle" class="game-view hidden">
                    <div class="symbolic-puzzle-container">
                        <div class="stone-slots" id="puzzle-slots"></div>
                        <div class="stone-palette" id="puzzle-palette"></div>
                    </div>
                    <section class="dialogue-container-puzzle">
                        <div class="dialogue-box">
                            <div
                                class="speaker-name hidden"
                                id="puzzle-speaker"
                            >
                            </div>
                            <div class="text-content" id="puzzle-text"></div>
                            <div class="click-prompt" id="puzzle-click-prompt">
                                ▼
                            </div>
                        </div>
                    </section>
                </div>
            </main>

            <!-- 対話鑑賞モード（恒久的アンロック） -->
            <div id="meditation-container" class="hidden">
                <header
                    class="meditation-header"
                    style="text-align: center; margin-bottom: 20px;"
                >
                    <h2
                        style="font-family: var(--font-serif); color: var(--color-gold); font-size: 24px; letter-spacing: 2px; text-shadow: 0 0 8px var(--color-gold-glow);"
                    >
                        DAILY TAROT
                    </h2>
                    <p
                        style="color: var(--color-text-muted); font-size: 13px; margin-top: 5px;"
                    >
                    ここはあなたの内省のための空間です。カードを引き、心惹かれるモチーフを見つめてみましょう。
                    </p>
                </header>
                <div class="meditation-card-display">
                    <div id="meditation-card-zone">
                        <button id="draw-meditation-btn" class="action-btn"
                            >カードを1枚引く</button
                        >
                    </div>
                </div>
                <div
                    id="meditation-dialogue"
                    class="dialogue-box hidden"
                    style="width: 100%; max-width: 600px; min-height: 120px; background: var(--color-bg-panel); border: var(--border-gold); padding: 15px; border-radius: 8px; backdrop-filter: var(--blur-glass); margin: 0 auto;"
                >
                    <div class="speaker-name" id="meditation-speaker">
                        内省の鏡
                    </div>
                    <div
                        class="text-content"
                        id="meditation-text"
                        style="font-size: 15px; line-height: 1.6;"
                    >
                    </div>
                </div>
                <div
                    id="meditation-motifs"
                    class="motif-container hidden"
                    style="margin-top: 15px;"
                >
                    <div class="motif-title">
                        惹かれるモチーフを選んでください
                    </div>
                    <div id="meditation-motif-buttons" class="motif-buttons">
                    </div>
                </div>
                <div style="text-align: center; margin-top: 20px; display: flex; justify-content: center; gap: 15px; flex-wrap: wrap;">
                    <button id="reset-meditation-btn" class="action-btn hidden">もう一度占う</button>
                    <button id="exit-meditation-btn" class="action-btn">タイトルに戻る</button>
                </div>
            </div>

            <!-- カード引き巨大表示用オーバーレイ -->
            <div id="card-draw-overlay" class="hidden">
                <div id="card-draw-deck-container"></div>
            </div>

            <!-- エンディング/オーバーレイ画面 -->
            <div id="ending-overlay" class="hidden">
                <div id="ending-particles"></div>
                <div class="ending-content">
                    <h1 id="ending-title">THE END</h1>
                    <p id="ending-desc">あなたは運命に敗北しました。</p>
                    <button id="restart-btn" class="action-btn"
                        >再び歩み始める</button
                    >
                </div>
            </div>
            <!-- 遊び方説明モーダル -->
            <div id="instructions-modal" class="custom-modal hidden">
                <div class="custom-modal-overlay"></div>
                <div class="custom-modal-content">
                    <button
                        id="close-instructions-btn"
                        class="custom-modal-close">&times;</button
                    >
                    <div class="instructions-image-wrapper">
                        <img
                            src="/images/tarot_instructions.png"
                            alt="Tarot Instructions"
                            class="instructions-img"
                        />
                    </div>
                </div>
            </div>

            <!-- バックログ（回想）モーダル -->
            <div id="backlog-modal" class="custom-modal hidden">
                <div class="custom-modal-overlay" id="backlog-modal-overlay"></div>
                <div class="custom-modal-content" style="width: 90%; max-width: 600px; max-height: 80vh; display: flex; flex-direction: column;">
                    <button
                        id="close-backlog-btn"
                        class="custom-modal-close"
                        style="position: absolute; top: 10px; right: 15px; background: none; border: none; color: var(--color-gold); font-size: 32px; cursor: pointer; z-index: 2002;"
                    >&times;</button>
                    <h3 style="font-family: var(--font-serif); color: var(--color-gold); font-size: 20px; margin-top: 0; margin-bottom: 15px; border-bottom: 1px solid rgba(212, 175, 55, 0.3); padding-bottom: 10px; width: 100%; text-align: center;">BACKLOG</h3>
                    <div id="backlog-list" style="flex: 1; width: 100%; overflow-y: auto; padding-right: 5px; font-size: 14px; line-height: 1.6; display: flex; flex-direction: column; gap: 12px; text-align: left;">
                        <!-- バックログテキストがここに入ります -->
                    </div>
                </div>
            </div>

            <!-- セーブスロット選択モーダル -->
            <div id="slots-modal" class="custom-modal hidden">
                <div class="custom-modal-overlay" id="slots-modal-overlay"></div>
                <div class="custom-modal-content" style="width: 95%; max-width: 450px; display: flex; flex-direction: column;">
                    <button
                        id="close-slots-btn"
                        class="custom-modal-close"
                        style="position: absolute; top: 10px; right: 15px; background: none; border: none; color: var(--color-gold); font-size: 32px; cursor: pointer;"
                    >&times;</button>
                    <h3 style="font-family: var(--font-serif); color: var(--color-gold); font-size: 20px; margin-top: 0; margin-bottom: 20px; border-bottom: 1px solid rgba(212, 175, 55, 0.3); padding-bottom: 10px; text-align: center;">SAVE / LOAD</h3>
                    <div id="slots-container" style="display: flex; flex-direction: column; gap: 15px; text-align: left; margin-bottom: 10px;">
                        <!-- スロットが動的に生成されます -->
                    </div>
                </div>
            </div>

            <!-- チャプター選択モーダル -->
            <div id="chapters-modal" class="custom-modal hidden">
                <div class="custom-modal-overlay" id="chapters-modal-overlay"></div>
                <div class="custom-modal-content" style="width: 95%; max-width: 480px; max-height: 80vh; display: flex; flex-direction: column;">
                    <button
                        id="close-chapters-btn"
                        class="custom-modal-close"
                        style="position: absolute; top: 10px; right: 15px; background: none; border: none; color: var(--color-gold); font-size: 32px; cursor: pointer; z-index: 2002;"
                    >&times;</button>
                    <h3 style="font-family: var(--font-serif); color: var(--color-gold); font-size: 20px; margin-top: 0; margin-bottom: 15px; border-bottom: 1px solid rgba(212, 175, 55, 0.3); padding-bottom: 10px; text-align: center;">CHAPTER SELECT</h3>
                    <div style="flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 20px; text-align: left; padding-right: 5px;">
                        <div>
                            <h4 style="color: var(--color-gold); margin: 0 0 10px; font-family: var(--font-serif); border-left: 2px solid var(--color-gold); padding-left: 8px; font-size: 14px;">LOOP 1 : 従属と歪み</h4>
                            <div style="display: flex; flex-direction: column; gap: 8px;">
                                <button class="chapter-select-btn" data-loop="1" data-step="0">始まりのタロット店 (Step 0)</button>
                                <button class="chapter-select-btn" data-loop="1" data-step="4">魔術師・知恵の檻 (Step 4)</button>
                                <button class="chapter-select-btn" data-loop="1" data-step="10">運命の輪・受動 (Step 10)</button>
                                <button class="chapter-select-btn" data-loop="1" data-step="15">悪魔・依存の檻 (Step 15)</button>
                                <button class="chapter-select-btn" data-loop="1" data-step="28">崩壊バッドエンド (Step 28)</button>
                            </div>
                        </div>
                        <div>
                            <h4 style="color: var(--color-gold); margin: 0 0 10px; font-family: var(--font-serif); border-left: 2px solid var(--color-gold); padding-left: 8px; font-size: 14px;">LOOP 2 : 自律と内省</h4>
                            <div style="display: flex; flex-direction: column; gap: 8px;">
                                <button class="chapter-select-btn" data-loop="2" data-step="3">占い師フィロとの対話 (Step 3)</button>
                                <button class="chapter-select-btn" data-loop="2" data-step="10">運命の車輪を回す (Step 10)</button>
                                <button class="chapter-select-btn" data-loop="2" data-step="15">悪魔の影を認める (Step 15)</button>
                                <button class="chapter-select-btn" data-loop="2" data-step="30">調和のトゥルーエンド (Step 30)</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- タロットカード全画面フォーカスモーダル -->
            <div id="card-focus-modal" class="custom-modal hidden">
                <div class="custom-modal-overlay"></div>
                <div class="custom-modal-content card-focus-content">
                    <div class="focus-card-image-container">
                        <div id="focus-card-img" class="focus-card-image"></div>
                        <div id="focus-card-highlight-box" class="focus-card-highlight-box hidden"></div>
                    </div>
                    <div class="focus-card-info">
                        <div id="focus-card-name" class="focus-card-name"></div>
                        <div
                            id="focus-card-direction"
                            class="focus-card-direction"
                        >
                        </div>

                        <div id="focus-card-tabs" class="focus-card-tabs hidden">
                            <button id="tab-game-desc" class="focus-tab-btn active">歪んだ解釈</button>
                            <button id="tab-true-desc" class="focus-tab-btn">本来の意味</button>
                        </div>

                        <div id="focus-card-desc" class="focus-card-desc"></div>

                        <!-- 注目モチーフのハイライト＆解説 -->
                        <div id="focus-card-motifs-section" class="focus-card-motifs-section hidden">
                            <div class="focus-motifs-title">🔍 注目モチーフを観察する</div>
                            <div id="focus-card-motif-buttons" class="focus-motif-buttons"></div>
                            <div id="focus-card-motif-explanation" class="focus-card-motif-explanation hidden"></div>
                        </div>
                    </div>
                    <div class="focus-card-tip">画面をタップして戻る</div>
                </div>
            </div>
            <!-- アプリ通知＆連携用 常設ボトムバー -->
            <div id="app-notification-bar" class="app-notification-bar hidden" style="cursor: pointer;">
                <div class="app-bar-inner">
                    <span class="app-bar-icon">📱</span>
                    <div class="app-bar-content" style="flex: 1;">
                        <span class="app-bar-title">THE JOURNEY</span>
                        <div id="app-bar-text" class="app-bar-text"></div>
                    </div>
                    <span class="app-bar-arrow" style="color: var(--color-gold); font-size: 16px; margin-left: 10px; opacity: 0.7;">❯</span>
                </div>
            </div>

        </div>

        <!-- 疑似スマートフォン型 アプリデバイス画面 -->
        <div id="app-device-modal" class="custom-modal hidden">
            <div class="custom-modal-overlay" id="app-device-overlay"></div>
            <div class="app-device-content">
                <!-- アプリのヘッダー -->
                <div class="app-device-header">
                    <div class="app-status-bar">
                        <span class="app-status-time">00:00</span>
                        <span class="app-status-signal">📶 🔋 100%</span>
                    </div>
                    <div class="app-title-bar">
                        <h2 class="app-main-title">THE JOURNEY</h2>
                        <button id="close-app-btn" class="app-close-btn"
                            >&times;</button
                        >
                    </div>
                    <!-- タブメニュー -->
                    <div class="app-tabs">
                        <button
                            id="app-tab-collection"
                            class="app-tab-btn active"
                            data-tab="collection">COLLECTION</button
                        >
                        <button
                            id="app-tab-vital"
                            class="app-tab-btn"
                            data-tab="vital">VITAL DATA</button
                        >
                    </div>
                </div>

                <!-- アプリのメインボディ -->
                <div class="app-device-body">
                    <!-- コレクション（カード図鑑）タブ -->
                    <div
                        id="app-panel-collection"
                        class="app-tab-panel active"
                    >
                        <div class="app-section-title">
                            発見したアルカナ
                        </div>
                        <div
                            id="app-collection-grid"
                            class="app-collection-grid"
                        >
                            <!-- JavaScriptで動的にカードを挿入 -->
                        </div>
                    </div>

                    <!-- バイタルデータタブ -->
                    <div id="app-panel-vital" class="app-tab-panel">
                        <div class="app-section-title">
                            バイタル・アナリティクス
                        </div>
                        <div class="vital-meters">
                            <div class="vital-meter-item">
                                <div class="vital-meter-label">
                                    STRESS LEVEL
                                </div>
                                <div class="vital-bar-container">
                                    <div
                                        id="vital-bar-stress"
                                        class="vital-bar stress"
                                        style="width: 0%;"
                                    >
                                    </div>
                                </div>
                                <div
                                    id="vital-text-stress"
                                    class="vital-meter-value"
                                >
                                    --%
                                </div>
                            </div>
                            <div class="vital-meter-item">
                                <div class="vital-meter-label">
                                    LUCK RATE
                                </div>
                                <div class="vital-bar-container">
                                    <div
                                        id="vital-bar-luck"
                                        class="vital-bar luck"
                                        style="width: 0%;"
                                    >
                                    </div>
                                </div>
                                <div
                                    id="vital-text-luck"
                                    class="vital-meter-value"
                                >
                                    --%
                                </div>
                            </div>
                        </div>
                        <!-- コンソールログ -->
                        <div class="vital-console">
                            <div class="console-header">
                                SYSTEM DIAGNOSTICS
                            </div>
                            <div
                                id="vital-console-log"
                                class="console-body"
                            >
                                <!-- タイピングログ -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- サーバーサイドでビルドしたシナリオデータをグローバル変数としてクライアントに渡す -->
        <script is:inline define:vars={{ scenarioData }}>
            window.SCENARIO_DATA = scenarioData;
        </script>
        <!-- クライアントサイドスクリプトのインポート -->
        <script>
            import "../scripts/app.js";
        </script>
    </body>
</html>
